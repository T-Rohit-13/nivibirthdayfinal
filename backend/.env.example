# ===== ENVIRONMENT VARIABLES =====
# Copy this file to .env and fill in your values.
# Never commit .env to git!

# MongoDB connection string (from Railway MongoDB plugin or MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/birthday_surprise

# Admin password — change this to something strong!
ADMIN_PASSWORD=bday2026nivi

# Secret key for signing JWT tokens — use a long random string
JWT_SECRET=change_this_to_a_long_random_secret_string_123456

# JWT expiry (e.g. 8h = 8 hours, 1d = 1 day)
JWT_EXPIRES_IN=8h

# Your Antigravity frontend URL (set this after deploying frontend)
# Example: https://your-site.antigravity.app
FRONTEND_URL=*

# Port (Railway sets this automatically, leave as 3000 for local)
PORT=3000
